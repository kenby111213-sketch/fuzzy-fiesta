# Sao chép file này thành .env và điền giá trị thật (KHÔNG commit .env)

# Chuỗi kết nối MongoDB Atlas
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net"

# Chuỗi bí mật ký token đăng nhập — đặt một chuỗi ngẫu nhiên dài, khó đoán
JWT_SECRET="thay-bang-chuoi-ngau-nhien-that-dai"

# Tài khoản quản lý tạo lúc seed (tùy chọn, mặc định admin / cafe123)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cafe123"
